pkgname=cockpit-oscap
pkgver=VERSION
pkgrel=1
pkgdesc='OpenSCAP compliance scanning for Cockpit'
arch=('x86_64')
url='https://github.com/swiftraccoon/cockpit-oscap'
license=(LGPL)
source=("SOURCE")
sha256sums=('SKIP')

package() {
  depends=(cockpit)
  cd $pkgname
  make DESTDIR="$pkgdir" install PREFIX=/usr
}
