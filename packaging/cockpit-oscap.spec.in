Name: cockpit-oscap
Version: %{VERSION}
Release: 1%{?dist}
Summary: OpenSCAP compliance scanning for Cockpit
License: LGPL-2.1-or-later

# distributions which ship nodejs-esbuild can rebuild the bundle during package build
%if 0%{?fedora} >= 42
%define rebuild_bundle 1
%endif

Source0: https://github.com/swiftraccoon/cockpit-oscap/releases/download/%{version}/%{name}-%{version}.tar.xz
Source1: https://github.com/swiftraccoon/cockpit-oscap/releases/download/%{version}/%{name}-node-%{version}.tar.xz

BuildArch: noarch
%if ! 0%{?suse_version}
ExclusiveArch: %{nodejs_arches} noarch
%endif
BuildRequires: make
%if 0%{?suse_version}
# Suse's package has a different name
BuildRequires: appstream-glib
%else
BuildRequires: libappstream-glib
%endif
BuildRequires: gettext
%if 0%{?rhel} && 0%{?rhel} <= 8
BuildRequires: libappstream-glib-devel
%endif
%if %{defined rebuild_bundle}
BuildRequires: /usr/bin/node
BuildRequires: nodejs-esbuild
%endif
BuildRequires: systemd-rpm-macros

Requires: cockpit-bridge
Requires: openscap-scanner
Requires: scap-security-guide
Requires: python3
Recommends: complyctl

%{NPM_PROVIDES}

%description
OpenSCAP compliance scanning for Cockpit.

Provides a web UI for running SCAP security scans, viewing compliance results,
managing scan schedules, editing tailoring profiles, and applying remediations
via the Cockpit web console.

%prep
%autosetup -n %{name}
%if %{defined rebuild_bundle}
%setup -q -D -T -a 1 -n %{name}
%endif

%build
%if %{defined rebuild_bundle}
rm -rf dist
# HACK: node module packaging is broken in Fedora ≤ 43; should be in
# common location, not major version specific one
NODE_ENV=production NODE_PATH=/usr/lib/node_modules:$(echo /usr/lib/node_modules_*) ./build.js
%else
# Use pre-built bundle on distributions without nodejs-esbuild
%endif


%install
%make_install PREFIX=/usr

# drop source maps, they are large and just for debugging
find %{buildroot}%{_datadir}/cockpit/ -name '*.map' | xargs --no-run-if-empty rm --verbose

# install the bridge script
install -D -m 0755 src/oscap-bridge.py %{buildroot}%{_datadir}/cockpit/oscap/oscap-bridge.py

# install systemd units
install -D -m 0644 systemd/cockpit-oscap-scan.service %{buildroot}%{_unitdir}/cockpit-oscap-scan.service
install -D -m 0644 systemd/cockpit-oscap-scan.timer %{buildroot}%{_unitdir}/cockpit-oscap-scan.timer

%check
appstream-util validate-relax --nonet %{buildroot}/%{_datadir}/metainfo/*

# this can't be meaningfully tested during package build; tests happen through
# FMF (see plans/all.fmf) during package gating

%post
%systemd_post cockpit-oscap-scan.service cockpit-oscap-scan.timer

%preun
%systemd_preun cockpit-oscap-scan.service cockpit-oscap-scan.timer

%postun
%systemd_postun_with_restart cockpit-oscap-scan.timer

%files
%doc README.md
%license LICENSE dist/index.js.LEGAL.txt
%{_datadir}/cockpit/*
%{_datadir}/metainfo/*
%{_unitdir}/cockpit-oscap-scan.service
%{_unitdir}/cockpit-oscap-scan.timer

%changelog
